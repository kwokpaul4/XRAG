# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=

# OpenAI API key — used for text-embedding-3-small
# Leave blank to use local Ollama embeddings instead
OPENAI_API_KEY=

# DeepSeek API (optional — used if ANTHROPIC_API_KEY is blank)
# Get key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat


OLLAMA_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen3.5:4b

# PostgreSQL connection
POSTGRES_URL=postgresql://xrag:xrag@localhost:5433/xrag

# ChromaDB
CHROMA_URL=http://localhost:8000

# Web server
PORT=3001
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info
