# Anthropic Claude API key (required)
ANTHROPIC_API_KEY=

# OpenAI API key — used for text-embedding-3-small
# Leave blank to use local Ollama embeddings instead
OPENAI_API_KEY=

# Ollama base URL (only needed if OPENAI_API_KEY is blank)
OLLAMA_URL=http://localhost:11434

# PostgreSQL connection
POSTGRES_URL=postgresql://xrag:xrag@localhost:5433/xrag

# ChromaDB
CHROMA_URL=http://localhost:8000

# Web server
PORT=3000
NODE_ENV=development

# Log level: debug | info | warn | error
LOG_LEVEL=info
