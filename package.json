{
  "name": "xrag",
  "version": "0.1.0",
  "description": "Multi-source RAG system with pluggable knowledge domains",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node --import tsx/esm infra/migrate.ts",
    "db:reset-vectors": "node --import tsx/esm infra/reset-vectors.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chromadb": "^1.9.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.67.3",
    "pdf-parse": "^1.1.1",
    "pg": "^8.13.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/pg": "^8.11.10",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.2",
    "vitest": "^2.1.4"
  }
}
